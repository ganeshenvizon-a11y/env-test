<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- Serves sitemap.php's output at the clean /sitemap.xml URL search engines expect. -->
        <rule name="Sitemap XML" stopProcessing="true">
          <match url="^sitemap\.xml$" />
          <action type="Rewrite" url="sitemap.php" />
        </rule>
        <!-- Serves robots.php's output at the clean /robots.txt URL, so its Sitemap: directive can reflect the current environment's domain. -->
        <rule name="Robots TXT" stopProcessing="true">
          <match url="^robots\.txt$" />
          <action type="Rewrite" url="robots.php" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
